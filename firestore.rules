rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── RBAC role helpers (superadmin > manager > staff; legacy admin/user) ──
    function actorRole() {
      let mapping = get(/databases/$(database)/documents/users_by_uid/$(request.auth.uid));
      return get(/databases/$(database)/documents/users/$(mapping.data.userId)).data.role;
    }
    function isSuperAdmin() {
      return actorRole() in ['superadmin', 'admin']; // legacy 'admin' = super admin
    }
    function isManagerOrAbove() {
      return actorRole() in ['superadmin', 'admin', 'manager'];
    }
    // Backward-compat alias used by existing rules: manager-or-above can manage.
    function isAdminByUid() {
      return isManagerOrAbove();
    }

    // ─── Existing collections ────────────────────────────────────────────────
    // Allow authenticated users to access their own data
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;

      // Super Admin manages everyone. A Manager may only edit Staff (current
      // role staff/user) and may not elevate them above Staff. A user may edit
      // their own doc but cannot change their own role.
      allow update: if request.auth != null && (
        isSuperAdmin() ||
        (isManagerOrAbove()
          && resource.data.role in ['staff', 'user']
          && request.resource.data.role in ['staff', 'user']) ||
        (resource.data.uid == request.auth.uid
          && request.resource.data.role == resource.data.role)
      );

      allow delete: if request.auth != null && (
        isSuperAdmin() ||
        (isManagerOrAbove() && resource.data.role in ['staff', 'user'])
      );
    }

    match /users_by_uid/{uidDoc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ─── Usage Tracking ──────────────────────────────────────────────────────
    match /usage_logs/{logId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && isAdminByUid();
    }

    match /chats/{chatId} {
      allow read, write: if request.auth != null;
    }

    match /chats/{chatId}/messages/{msgId} {
      allow read, write: if request.auth != null;
    }

    match /knowledge/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /knowledge_vectors/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /kb_articles/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /generated_assets/{assetId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ─── Organizations ──────────────────────────────────────────────────────
    match /organizations/{orgId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isSuperAdmin(); // super admin only
    }

    match /org_members/{memberId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ─── Company News ────────────────────────────────────────────────────────

    // ─── Projects ────────────────────────────────────────────────────────────
    match /projects/{projectId} {
      allow read, write: if request.auth != null;
    }

    match /news_posts/{postId} {
      // Admin can do anything
      allow create: if request.auth != null && isAdminByUid();
      allow update: if request.auth != null && isAdminByUid();
      allow delete: if request.auth != null && isAdminByUid();

      // Any authenticated user can read news posts.
      // Client-side filters handle visibility, timing, and draft hiding for non-admins.
      allow read: if request.auth != null;
    }

    // Audit trail: super admin only writes, anyone authenticated can read
    match /news_audit/{auditId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isSuperAdmin();
    }

    // ─── Time Clock (punch in/out) ───────────────────────────────────────────
    // A user reads/writes their own entries (clock in/out). Admins/managers can
    // read, adjust, add, and delete anyone's entries.
    match /time_entries/{entryId} {
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid || isAdminByUid()
      );
      allow create: if request.auth != null && (
        request.resource.data.userId == request.auth.uid || isAdminByUid()
      );
      allow update, delete: if request.auth != null && (
        resource.data.userId == request.auth.uid || isAdminByUid()
      );
    }

    // ─── Default deny ────────────────────────────────────────────────────────
    // Everything else is denied by default
  }
}
