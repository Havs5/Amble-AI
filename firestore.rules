rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper: resolve admin via UID mapping ─────────────────────────────
    function isAdminByUid() {
      let mapping = get(/databases/$(database)/documents/users_by_uid/$(request.auth.uid));
      let userId = mapping.data.userId;
      return get(/databases/$(database)/documents/users/$(userId)).data.role in ['admin', 'superadmin'];
    }

    // ─── Existing collections ────────────────────────────────────────────────
    // Allow authenticated users to access their own data
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (
        resource.data.uid == request.auth.uid ||
        isAdminByUid()
      );
    }

    match /users_by_uid/{uidDoc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ─── Usage Tracking ──────────────────────────────────────────────────────
    match /usage_logs/{logId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && isAdminByUid();
    }

    match /chats/{chatId} {
      allow read, write: if request.auth != null;
    }

    match /chats/{chatId}/messages/{msgId} {
      allow read, write: if request.auth != null;
    }

    match /knowledge/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /knowledge_vectors/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /kb_articles/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /generated_assets/{assetId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ─── Company News ────────────────────────────────────────────────────────

    // Helper function: is the requester an admin?
    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'superadmin'];
    }

    match /news_posts/{postId} {
      // Admin can do anything
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();

      // Users can read PUBLISHED posts that pass timing + visibility checks
      // (Fine-grained timing/visibility is enforced client-side; rules ensure status check)
      allow read: if request.auth != null && (
        // Admins can read all (including drafts)
        isAdmin() ||
        // Users can only read published posts
        resource.data.status == 'PUBLISHED'
      );
    }

    // Audit trail: only admin can write, anyone authenticated can read
    match /news_audit/{auditId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ─── Default deny ────────────────────────────────────────────────────────
    // Everything else is denied by default
  }
}
